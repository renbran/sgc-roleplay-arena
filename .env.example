# Example environment variables
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT secret for auth (required in production)
JWT_SECRET="your_jwt_secret"

# CSRF secret (required for production)
CSRF_SECRET="your_csrf_secret"

# Deepgram API key (primary ASR provider + TTS engine)
DEEPGRAM_API_KEY="your_deepgram_key"

# Groq API key (fallback ASR provider using Whisper large-v3-turbo)
GROQ_API_KEY="your_groq_key"

# Mem0 API key
MEM0_API_KEY="your_mem0_key"

# LiveKit (real-time voice agent) — only needed if using LiveKit pipeline
LIVEKIT_URL="wss://your-livekit-instance.com"
LIVEKIT_API_KEY="your_livekit_api_key"
LIVEKIT_API_SECRET="your_livekit_api_secret"
# LIVEKIT_ENABLE_DISPATCH="true"
# LIVEKIT_AGENT_NAME="test-agent"
