# Database - Provision at https://neon.tech (free tier)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Deepgram TTS/ASR - https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# LiveKit voice rooms - https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ENABLE_DISPATCH=true
LIVEKIT_AGENT_NAME=test-agent

# App password gate (client-side, must use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_PASSWORD=SGC2025

# Node environment
NODE_ENV=production

# Admin dashboard server-side password (do not prefix with NEXT_PUBLIC_)
ADMIN_PASSWORD=change_me
